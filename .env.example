# ═══════════════════════════════════════════════════════════════
# Notion 配置
# ═══════════════════════════════════════════════════════════════

# Notion Integration Token（选填，使用 Notion 同步时必填）
# 创建 Integration：https://www.notion.so/my-integrations
# Token 以 ntn_ 或 secret_ 开头
NOTION_TOKEN=your_notion_token_here

# Notion 数据库 ID（选填，使用 Notion 同步时必填）
# 打开数据库页面，URL 中 notion.so/ 后面那串 32 位字符就是 ID
# 例如：https://www.notion.so/myworkspace/a8aec43384f447ed84390e8e42c2e089?v=...
# 数据库 ID 就是 a8aec43384f447ed84390e8e42c2e089
NOTION_DATABASE_ID=your_database_id_here

# ═══════════════════════════════════════════════════════════════
# DeepSeek AI 配置
# ═══════════════════════════════════════════════════════════════

# DeepSeek API 密钥（必填）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek 模型名称（可选，默认 deepseek-chat）
DEEPSEEK_MODEL=deepseek-chat

# DeepSeek API 地址（可选，默认 https://api.deepseek.com/v1/chat/completions）
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ═══════════════════════════════════════════════════════════════
# 期刊生成配置（可选）
# ═══════════════════════════════════════════════════════════════

# 期刊生成最低文章数阈值
# DIGEST_MIN_WEEKLY=2
# DIGEST_MIN_MONTHLY=3
# DIGEST_MIN_QUARTERLY=5
# DIGEST_MIN_YEARLY=10
