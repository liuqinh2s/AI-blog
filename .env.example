# ═══════════════════════════════════════════════════════════════
# Notion 配置
# ═══════════════════════════════════════════════════════════════

# Notion Integration Token（选填，使用 Notion 同步时必填）
# 创建 Integration：https://www.notion.so/my-integrations
# Token 以 ntn_ 或 secret_ 开头
NOTION_TOKEN=your_notion_token_here

# Notion 数据库 ID（选填，使用 Notion 同步时必填）
# 打开数据库页面，URL 中 notion.so/ 后面那串 32 位字符就是 ID
# 例如：https://www.notion.so/myworkspace/a8aec43384f447ed84390e8e42c2e089?v=...
# 数据库 ID 就是 a8aec43384f447ed84390e8e42c2e089
NOTION_DATABASE_ID=your_database_id_here

# ═══════════════════════════════════════════════════════════════
# DeepSeek AI 配置
# ═══════════════════════════════════════════════════════════════

# DeepSeek API 密钥（必填）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek 模型名称（可选，默认 deepseek-chat）
DEEPSEEK_MODEL=deepseek-chat

# DeepSeek API 地址（可选，默认 https://api.deepseek.com/v1/chat/completions）
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ═══════════════════════════════════════════════════════════════
# 期刊生成配置（可选）
# ═══════════════════════════════════════════════════════════════

# 期刊生成最低文章数阈值
# DIGEST_MIN_WEEKLY=2
# DIGEST_MIN_MONTHLY=3
# DIGEST_MIN_QUARTERLY=5
# DIGEST_MIN_YEARLY=10

# ═══════════════════════════════════════════════════════════════
# 多平台分发配置（选填，配置哪个平台就分发到哪个平台）
# ═══════════════════════════════════════════════════════════════

# --- 微信公众号 ---
# 登录微信公众平台 → 开发 → 基本配置 → 获取 AppID 和 AppSecret
# 注意：需要已认证的服务号才能使用草稿箱 API
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_secret_here

# --- 微博 ---
# 微博开放平台：https://open.weibo.com/
# 创建应用后获取 access_token（需要 statuses_to_me_read 权限）
WEIBO_ACCESS_TOKEN=your_weibo_access_token_here

# --- 推特/X ---
# Twitter Developer Portal：https://developer.twitter.com/
# 创建 App 后获取以下四个凭证（需要 OAuth 1.0a）
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# --- 知识星球 ---
# 通过浏览器抓包获取 access_token 和 group_id
# 登录知识星球网页版 → F12 → Network → 找到 api.zsxq.com 请求
ZSXQ_ACCESS_TOKEN=your_zsxq_access_token_here
ZSXQ_GROUP_ID=your_zsxq_group_id_here

# --- 小红书 ---
# 小红书没有官方 API，脚本会生成适配内容保存到 distribute_output/ 目录
# 你只需手动复制粘贴到小红书即可（最安全的方式，不会触发风控）
